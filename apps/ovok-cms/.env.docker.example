# Copy to `.env` to override the docker-compose defaults.
#
# DATABASE_URI is auto-set to the in-network Postgres by the compose file —
# only override if you want to point at a different DB.
#
# PAYLOAD_INTERNAL_API_KEY MUST match the value set on the ovok-internal
# backend; the proxy authenticates with this header. Any random hex string
# works for local; just keep both sides in sync.

PAYLOAD_SECRET=dev-not-a-real-secret-change-me
PAYLOAD_INTERNAL_API_KEY=dev-internal-key-change-me
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001
